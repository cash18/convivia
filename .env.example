# --- Postgres (obbligatorio) ---
# Su Vercel+Neon queste variabili sono già create dall’integrazione.
# In locale: DATABASE_URL (pooler) e DATABASE_URL_UNPOOLED (host diretto); se non usi il pooler, stessa stringa per entrambe.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/neondb?sslmode=require"

# --- Auth.js / NextAuth ---
AUTH_SECRET="genera-con-openssl-rand-base64-32"
# In produzione su Vercel: URL pubblico del sito (es. https://convivia-xxx.vercel.app)
AUTH_URL="http://localhost:3000"
