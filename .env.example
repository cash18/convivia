# --- Postgres (obbligatorio: locale, Vercel + Neon, ecc.) ---
# Su Neon: "pooled" / transaction → DATABASE_URL; "direct" → DIRECT_URL (migrazioni).
# In locale senza pooler puoi usare la stessa stringa per entrambe.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# --- Auth.js / NextAuth ---
AUTH_SECRET="genera-con-openssl-rand-base64-32"
# In produzione su Vercel: URL pubblico del sito (es. https://convivia-xxx.vercel.app)
AUTH_URL="http://localhost:3000"
