// Convivia — modelli dati (Postgres in produzione / Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  passwordHash         String
  name                 String
  createdAt            DateTime               @default(now())
  /// Impostata al completamento del link di verifica email (obbligatorio per accedere).
  emailVerifiedAt      DateTime?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  houseEmailInvitesSent   HouseEmailInvite[]       @relation("HouseInviteSender")
  ownershipTransfersFrom  HouseOwnershipTransfer[] @relation("OwnershipFrom")
  ownershipTransfersTo    HouseOwnershipTransfer[] @relation("OwnershipTo")
  memberships          HouseMember[]
  expensesPaid         Expense[]              @relation("ExpensePayer")
  expenseSplits        ExpenseSplit[]
  transfersSent        MoneyTransfer[]        @relation("TransferFrom")
  transfersReceived    MoneyTransfer[]        @relation("TransferTo")
  transfersRecorded    MoneyTransfer[]        @relation("TransferRecorder")
  eventsCreated        CalendarEvent[]        @relation("EventCreator")
  tasksAssigned        Task[]                 @relation("TaskAssignee")
  tasksCreated         Task[]                 @relation("TaskCreator")
  shoppingItems        ShoppingListItem[]     @relation("ItemAdder")
  webPushSubscriptions WebPushSubscription[]
  /// Preferenze notifiche push per categoria (`EXPENSES`, `CALENDAR`, …). Null = tutte attive.
  pushNotifyPrefs      Json?
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Invito a unirsi a una casa tramite link email (oltre al codice manuale).
model HouseEmailInvite {
  id              String    @id @default(cuid())
  token           String    @unique
  houseId         String
  email           String
  invitedByUserId String
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  house           House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  invitedBy       User      @relation("HouseInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([houseId])
}

/// Richiesta di trasferimento proprietà (OWNER); il destinatario conferma via email.
model HouseOwnershipTransfer {
  id          String    @id @default(cuid())
  houseId     String
  fromUserId  String
  toUserId    String
  token       String    @unique
  /// PENDING | ACCEPTED | DECLINED | CANCELLED
  status      String    @default("PENDING")
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  fromUser    User      @relation("OwnershipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser      User      @relation("OwnershipTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([houseId])
  @@index([toUserId])
}

/// Iscrizione Web Push (PWA) per notifiche attività nella casa.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model House {
  id                 String   @id @default(cuid())
  name               String
  inviteCode         String   @unique
  /// Segreto per URL feed ICS (Google Calendar / Apple); rigenerabile.
  calendarFeedToken  String   @unique
  createdAt          DateTime @default(now())
  members    HouseMember[]
  expenses   Expense[]
  moneyTransfers MoneyTransfer[]
  events     CalendarEvent[]
  lists      ShoppingList[]
  tasks      Task[]
  emailInvites         HouseEmailInvite[]
  ownershipTransfers HouseOwnershipTransfer[]
}

model HouseMember {
  id       String   @id @default(cuid())
  userId   String
  houseId  String
  /// OWNER (creatore / proprietario) | SUPERVISOR (gestione membri) | MEMBER
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  house    House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model Expense {
  id          String         @id @default(cuid())
  houseId     String
  title       String
  amountCents Int
  paidById    String
  expenseDate DateTime       @default(now())
  notes       String?
  /// EQUAL | PERCENT (somma 100%) | CUSTOM (importi € per persona, somma = totale)
  splitMode   String         @default("EQUAL")
  /// Data URL (es. image/jpeg;base64,...) o URL HTTPS (es. Blob)
  receiptUrl  String?
  createdAt   DateTime       @default(now())
  house       House          @relation(fields: [houseId], references: [id], onDelete: Cascade)
  paidBy      User           @relation("ExpensePayer", fields: [paidById], references: [id])
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id           String  @id @default(cuid())
  expenseId    String
  userId       String
  shareCents   Int
  /// Percentuale 1–100 se splitMode PERCENT; null se EQUAL
  sharePercent Int?
  expense      Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

/// Trasferimento di denaro tra membri (non è una spesa): utile per pareggiare i conti.
model MoneyTransfer {
  id            String   @id @default(cuid())
  houseId       String
  fromUserId    String
  toUserId      String
  amountCents   Int
  note          String?
  transferDate  DateTime @default(now())
  createdById   String
  createdAt     DateTime @default(now())
  house         House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  fromUser      User     @relation("TransferFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser        User     @relation("TransferTo", fields: [toUserId], references: [id], onDelete: Cascade)
  createdBy     User     @relation("TransferRecorder", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([houseId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  houseId     String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("EventCreator", fields: [createdById], references: [id])
}

model ShoppingList {
  id        String             @id @default(cuid())
  houseId   String
  name      String
  createdAt DateTime           @default(now())
  house     House              @relation(fields: [houseId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id         String   @id @default(cuid())
  listId     String
  name       String
  done       Boolean  @default(false)
  addedById  String?
  createdAt  DateTime @default(now())
  list       ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedBy    User?    @relation("ItemAdder", fields: [addedById], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  houseId     String
  title       String
  description String?
  assigneeId  String?
  dueDate     DateTime?
  status      String    @default("TODO") // TODO | DONE
  createdById String
  createdAt   DateTime  @default(now())
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("TaskCreator", fields: [createdById], references: [id])
}
