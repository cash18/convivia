// Convivia — modelli dati (Postgres in produzione / Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id                   String                 @id @default(cuid())
  email                String                 @unique
  passwordHash         String
  name                 String
  createdAt            DateTime               @default(now())
  memberships          HouseMember[]
  expensesPaid         Expense[]              @relation("ExpensePayer")
  expenseSplits        ExpenseSplit[]
  eventsCreated        CalendarEvent[]        @relation("EventCreator")
  tasksAssigned        Task[]                 @relation("TaskAssignee")
  tasksCreated         Task[]                 @relation("TaskCreator")
  shoppingItems        ShoppingListItem[]     @relation("ItemAdder")
  webPushSubscriptions WebPushSubscription[]
  /// Preferenze notifiche push per categoria (`EXPENSES`, `CALENDAR`, …). Null = tutte attive.
  pushNotifyPrefs      Json?
}

/// Iscrizione Web Push (PWA) per notifiche attività nella casa.
model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model House {
  id                 String   @id @default(cuid())
  name               String
  inviteCode         String   @unique
  /// Segreto per URL feed ICS (Google Calendar / Apple); rigenerabile.
  calendarFeedToken  String   @unique
  createdAt          DateTime @default(now())
  members    HouseMember[]
  expenses   Expense[]
  events     CalendarEvent[]
  lists      ShoppingList[]
  tasks      Task[]
}

model HouseMember {
  id       String   @id @default(cuid())
  userId   String
  houseId  String
  role     String   @default("MEMBER") // OWNER | MEMBER
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  house    House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model Expense {
  id          String         @id @default(cuid())
  houseId     String
  title       String
  amountCents Int
  paidById    String
  expenseDate DateTime       @default(now())
  notes       String?
  /// EQUAL = riparto uguale; PERCENT = riparto per percentuali (somma 100)
  splitMode   String         @default("EQUAL")
  /// Data URL (es. image/jpeg;base64,...) o URL HTTPS (es. Blob)
  receiptUrl  String?
  createdAt   DateTime       @default(now())
  house       House          @relation(fields: [houseId], references: [id], onDelete: Cascade)
  paidBy      User           @relation("ExpensePayer", fields: [paidById], references: [id])
  splits      ExpenseSplit[]
}

model ExpenseSplit {
  id           String  @id @default(cuid())
  expenseId    String
  userId       String
  shareCents   Int
  /// Percentuale 1–100 se splitMode PERCENT; null se EQUAL
  sharePercent Int?
  expense      Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model CalendarEvent {
  id          String    @id @default(cuid())
  houseId     String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  allDay      Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("EventCreator", fields: [createdById], references: [id])
}

model ShoppingList {
  id        String             @id @default(cuid())
  houseId   String
  name      String
  createdAt DateTime           @default(now())
  house     House              @relation(fields: [houseId], references: [id], onDelete: Cascade)
  items     ShoppingListItem[]
}

model ShoppingListItem {
  id         String   @id @default(cuid())
  listId     String
  name       String
  done       Boolean  @default(false)
  addedById  String?
  createdAt  DateTime @default(now())
  list       ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedBy    User?    @relation("ItemAdder", fields: [addedById], references: [id])
}

model Task {
  id          String    @id @default(cuid())
  houseId     String
  title       String
  description String?
  assigneeId  String?
  dueDate     DateTime?
  status      String    @default("TODO") // TODO | DONE
  createdById String
  createdAt   DateTime  @default(now())
  house       House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy   User      @relation("TaskCreator", fields: [createdById], references: [id])
}
